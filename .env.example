# === AI Holding Configuration ===

# App
DEBUG=false
SECRET_KEY=your-secret-key-here

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://kimi:kimi@postgres:5432/ai_holding

# Redis
REDIS_URL=redis://redis:6379/0

# Google Cloud / Vertex AI
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=global
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/gcp-key.json

# LLM Model tiers
LLM_FAST=google/gemini-3.1-flash-lite-preview
LLM_SMART=deepseek-ai/deepseek-v3.2-maas
LLM_REASONING=claude-sonnet-4-6

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_OWNER_CHAT_ID=your-telegram-chat-id

# OANDA Forex (Practice account)
OANDA_API_KEY=your-oanda-api-key
OANDA_ACCOUNT_ID=your-oanda-account-id
OANDA_API_URL=https://api-fxpractice.oanda.com

# Agent settings
APPROVAL_TIMEOUT_HOURS=24
AUTO_APPROVE_BELOW_USD=10.0
